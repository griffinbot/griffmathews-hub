---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Contact" description="Get in touch with Griff.">
  <section class="section">
    <div class="container">
      <div class="section-title">
        <h2>Contact</h2>
        <div class="underline"></div>
        <p class="section-sub">Want to build something? Email me and I’ll get back to you.</p>
      </div>

      <div class="center">
        <a class="btn btn-primary" href="mailto:griffmathews@icloud.com">Email Me</a>
      </div>

      <div class="section-title" style="margin-top: 34px;">
        <p class="section-sub">
          You can also find me on <a href="https://github.com/" target="_blank" rel="noreferrer">GitHub</a> and{" "}
          <a href="https://www.linkedin.com/" target="_blank" rel="noreferrer">LinkedIn</a>.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

