---
import BaseLayout from "../layouts/BaseLayout.astro";

const updates = [
  { date: "Mar 2026", title: "Landing refresh", note: "Cleaner structure for sharing." },
  { date: "Feb 2026", title: "Portfolio launch", note: "Core pages are now live." },
  { date: "Jan 2026", title: "First app shipped", note: "Weather app released." },
];
---

<BaseLayout title="Updates" description="Latest updates from Griff Mathews.">
  <section class="section section-muted">
    <div class="container">
      <div class="section-title">
        <h2>Updates</h2>
        <div class="underline"></div>
        <p class="section-sub">Recent changes, no noise.</p>
      </div>

      <div class="updates-rail">
        {updates.map((item) => (
          <article class="update-card">
            <p class="update-card-date">{item.date}</p>
            <h3>{item.title}</h3>
            <p>{item.note}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
