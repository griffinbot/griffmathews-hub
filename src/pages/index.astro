---
import BaseLayout from "../layouts/BaseLayout.astro";

const description = "Clear software for small teams and founders who need useful tools without extra complexity.";
---

<BaseLayout title="Griff Mathews" description={description}>
  <main id="top" class="home-hero">
    <div class="container home-hero-inner">
      <p class="eyebrow">Available for projects</p>
      <h1>Clear software for teams that need useful tools fast.</h1>
      <p class="hero-sub">I help small teams and founders turn messy work into simple web apps, automations, and interactive products people can actually use.</p>

      <div class="hero-actions">
        <a class="btn btn-primary" href="/contact">Get In Touch</a>
        <a class="btn btn-secondary" href="/projects">See Projects</a>
      </div>

      <p class="hero-note">Open to new projects. Typical reply within 1 to 2 business days.</p>
    </div>
  </main>

  <section id="projects" class="section">
    <div class="container">
      <div class="section-title">
        <h2>What I Build</h2>
        <p class="section-sub">Most projects come down to a product people can use, a workflow that should run itself, or an idea that needs a focused interactive experience.</p>
      </div>

      <div class="cards3">
        <article class="card">
          <div class="card-kicker">Need a product</div>
          <h3>A simple app people can use</h3>
          <p>Full-stack web apps with clear flows, solid engineering, and only the features that matter.</p>
        </article>

        <article class="card">
          <div class="card-kicker">Need less busywork</div>
          <h3>A workflow that runs itself</h3>
          <p>Automations and internal tools that cut repetitive steps and make day-to-day work easier to manage.</p>
        </article>

        <article class="card">
          <div class="card-kicker">Need engagement</div>
          <h3>An interactive idea with focus</h3>
          <p>Games and interactive builds that feel polished, purposeful, and easy for users to understand.</p>
        </article>
      </div>
    </div>
  </section>

  <section id="updates" class="section section-muted section-compact">
    <div class="container">
      <div class="section-title">
        <h2>Latest Updates</h2>
        <p class="section-sub">A short look at recent shipping and site updates.</p>
      </div>

      <div class="updates-list">
        <article class="update-row">
          <p class="update-date">Mar 9, 2026</p>
          <div>
            <h3>Dev Branch Lab</h3>
            <p>Added a dedicated space for testing features and experiments before they reach production.</p>
          </div>
        </article>

        <article class="update-row">
          <p class="update-date">Feb 3, 2026</p>
          <div>
            <h3>New portfolio launch</h3>
            <p>Rebuilt the site to make projects, updates, and experiments easier to scan.</p>
          </div>
        </article>
      </div>

      <div class="center">
        <a class="btn btn-secondary" href="/updates">View All Updates</a>
      </div>
    </div>
  </section>
</BaseLayout>
