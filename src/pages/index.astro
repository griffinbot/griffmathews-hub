---
import BaseLayout from "../layouts/BaseLayout.astro";

const description = "Building innovative web apps, automations, and games that solve real problems.";
---

<BaseLayout title="Griff Mathews" description={description}>
  <main id="top" class="hero-wrap">
    <div class="container hero">
      <div class="pill">
        <span class="dot"></span>
        Available for projects
      </div>

      <h1 class="hero-title">
        <span class="grad">Griff</span>
        <span class="grad2">Mathews</span>
      </h1>

      <p class="hero-sub">
        Building innovative web apps, automations, and games that solve<br />
        real problems
      </p>

      <a class="btn btn-primary" href="/projects">
        View My Work <span class="chev">⌄</span>
      </a>
    </div>

    <div class="corner corner-left" aria-hidden="true"></div>
    <div class="corner corner-right" aria-hidden="true"></div>
  </main>

  <section id="projects" class="section">
    <div class="container">
      <div class="section-title">
        <h2>What I Build</h2>
        <div class="underline"></div>
      </div>

      <div class="cards3">
        <article class="card outline-orange">
          <div class="iconbox orange">{"<>"}</div>
          <h3>Web Apps</h3>
          <p>Full-stack applications built with modern technologies and best practices</p>
        </article>

        <article class="card outline-blue">
          <div class="iconbox blue">⚡</div>
          <h3>Automations</h3>
          <p>Workflow automations and tools that streamline processes and boost productivity</p>
        </article>

        <article class="card outline-orange">
          <div class="iconbox orange">🎮</div>
          <h3>Games</h3>
          <p>Interactive experiences and games that engage and entertain users</p>
        </article>
      </div>
    </div>
  </section>

  <section id="updates" class="section section-muted">
    <div class="container">
      <div class="section-title">
        <h2>Latest Updates</h2>
        <div class="underline"></div>
        <p class="section-sub">Stay up to date with new projects, releases, and documentation</p>
      </div>

      <div class="updates">
        <article class="update highlight">
          <div class="u-icon orange">🔔</div>
          <div class="u-body">
            <div class="u-meta">
              <span class="tag orange">Announcement</span>
              <span class="date">Feb 3, 2026</span>
            </div>
            <h3>New Portfolio Website Launch</h3>
            <p>
              Excited to share my new portfolio showcasing all my projects in web apps, automations,
              and games. Built for speed and clarity.
            </p>
          </div>
        </article>

        <article class="update">
          <div class="u-icon blue">📄</div>
          <div class="u-body">
            <div class="u-meta">
              <span class="tag blue">Documentation</span>
              <span class="date">Jan 28, 2026</span>
            </div>
            <h3>Documentation Updates</h3>
            <p>Added guides for setting up and deploying web applications. More tutorials coming soon.</p>
          </div>
        </article>

        <article class="update">
          <div class="u-icon orange">💡</div>
          <div class="u-body">
            <div class="u-meta">
              <span class="tag orange">Release</span>
              <span class="date">Jan 20, 2026</span>
            </div>
            <h3>New Automation Tool Released</h3>
            <p>Released a new automation tool that helps streamline workflow processes. Early access testing open.</p>
          </div>
        </article>

        <article class="update hidden" data-more>
          <div class="u-icon blue">🧪</div>
          <div class="u-body">
            <div class="u-meta">
              <span class="tag blue">Update</span>
              <span class="date">Jan 14, 2026</span>
            </div>
            <h3>Experiment: New UI System</h3>
            <p>Started a lightweight component system for faster prototyping across apps.</p>
          </div>
        </article>

        <article class="update hidden" data-more>
          <div class="u-icon orange">🚀</div>
          <div class="u-body">
            <div class="u-meta">
              <span class="tag orange">Build</span>
              <span class="date">Jan 10, 2026</span>
            </div>
            <h3>First App Scaffolded</h3>
            <p>Project structure is in place - next step is shipping a public MVP under a subdomain.</p>
          </div>
        </article>
      </div>

      <div class="center">
        <button class="btn btn-outline" id="loadMore" type="button">Load More Updates</button>
      </div>
    </div>
  </section>

  <script type="module">
    const button = document.getElementById("loadMore");

    button?.addEventListener("click", () => {
      document.querySelectorAll("[data-more].hidden").forEach((element) => {
        element.classList.remove("hidden");
      });

      button.style.display = "none";
    });
  </script>
</BaseLayout>
