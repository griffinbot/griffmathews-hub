---
import BaseLayout from "../layouts/BaseLayout.astro";

const description = "Minimal landing page for apps, updates, and about.";

const sections = [
  {
    title: "Apps",
    body: "Useful tools, shipped clean.",
    href: "/projects",
    cta: "View apps",
    accent: "orange",
  },
  {
    title: "Updates",
    body: "Quick notes on what is live now.",
    href: "/updates",
    cta: "Read updates",
    accent: "blue",
  },
  {
    title: "About",
    body: "Who I am and how I build.",
    href: "/about",
    cta: "About me",
    accent: "orange",
  },
];
---

<BaseLayout title="Home" description={description}>
  <main>
    <section class="section">
      <div class="container">
        <div class="section-title">
          <h2>Griff Mathews</h2>
          <div class="underline"></div>
          <p class="section-sub">Web apps. Automation. Interactive builds.</p>
        </div>

        <div class="featured-grid">
          {sections.map((section) => (
            <article class={`feature-panel feature-panel-${section.accent}`}>
              <h3>{section.title}</h3>
              <p>{section.body}</p>
              <a class="feature-link" href={section.href}>
                {section.cta}
                <span aria-hidden="true">↗</span>
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
