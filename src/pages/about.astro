---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="About" description="A little about Griff and what I build.">
  <section class="section">
    <div class="container">
      <div class="section-title">
        <h2>About</h2>
        <div class="underline"></div>
        <p class="section-sub">
          I build web apps, automations, and games—focused on solving real problems with clean UX and reliable
          engineering.
        </p>
      </div>

      <div class="section-title">
        <p class="section-sub">
          If you have an idea you want to ship (or a workflow you want to streamline), I’m available for projects.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

