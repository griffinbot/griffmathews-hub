---
import BaseLayout from "../layouts/BaseLayout.astro";

const apps = [
  {
    name: "Weather",
    detail: "Fast local forecast.",
    href: "https://weather.griffmathews.com",
    cta: "Open",
  },
  {
    name: "Mini Crossword",
    detail: "Daily puzzle, short and clean.",
    href: "/crossword",
    cta: "Play",
  },
  {
    name: "Automation Tools",
    detail: "Internal workflows in progress.",
    href: "/contact",
    cta: "Ask",
  },
];
---

<BaseLayout title="Apps" description="Apps and tools by Griff Mathews.">
  <section class="section">
    <div class="container">
      <div class="section-title">
        <h2>Apps</h2>
        <div class="underline"></div>
        <p class="section-sub">Small, useful, and polished.</p>
      </div>

      <div class="featured-grid">
        {apps.map((app, index) => (
          <article class={`feature-panel ${index % 2 === 0 ? "feature-panel-orange" : "feature-panel-blue"}`}>
            <h3>{app.name}</h3>
            <p>{app.detail}</p>
            <a class="feature-link" href={app.href}>{app.cta} <span aria-hidden="true">↗</span></a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
