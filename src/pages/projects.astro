---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Projects" description="Web apps, automations, and games I build.">
  <section class="section">
    <div class="container">
      <div class="section-title">
        <h2>What I Build</h2>
        <div class="underline"></div>
        <p class="section-sub">Web apps, automations, and games—built for speed, clarity, and real-world impact.</p>
      </div>

      <div class="cards3">
        <article class="card outline-orange">
          <div class="iconbox orange">〈〉</div>
          <h3>Web Apps</h3>
          <p>Full-stack applications built with modern technologies and best practices</p>
        </article>

        <article class="card outline-blue">
          <div class="iconbox blue">⚡</div>
          <h3>Automations</h3>
          <p>Workflow automations and tools that streamline processes and boost productivity</p>
        </article>

        <article class="card outline-orange">
          <div class="iconbox orange">🎮</div>
          <h3>Games</h3>
          <p>Interactive experiences and games that engage and entertain users</p>
        </article>


        <article class="card outline-orange">
          <div class="iconbox orange">🧩</div>
          <h3>Mini Crossword</h3>
          <p>A classic clue-based mini crossword with timer, check/reveal, and pencil mode.</p>
          <a class="btn btn-primary card-cta" href="/crossword">Play Mini Crossword</a>
        </article>

        <article class="card outline-blue">
          <div class="iconbox blue">☀️</div>
          <h3>Weather App</h3>
          <p>Live weather forecasts and location-based conditions in a fast, simple interface</p>
          <a class="btn btn-primary card-cta" href="https://weather.griffmathews.com" target="_blank" rel="noopener noreferrer">
            Open Weather App
          </a>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>

