---
import BaseLayout from "../layouts/BaseLayout.astro";

const projects = [
  {
    name: "Weather App",
    detail: "Fast local forecasts and current conditions in a clean interface.",
    href: "https://weather.griffmathews.com",
    cta: "Launch",
  },
  {
    name: "Mini Crossword",
    detail: "A focused daily puzzle with keyboard-friendly controls.",
    href: "/crossword",
    cta: "Play",
  },
  {
    name: "Automation Tools",
    detail: "Workflow tools and automations built to streamline repeatable work.",
    href: "/contact",
    cta: "Ask About",
  },
];
---

<BaseLayout title="Projects" description="Projects and tools by Griff Mathews.">
  <section class="section">
    <div class="container">
      <div class="section-title">
        <h2>Projects</h2>
        <div class="underline"></div>
        <p class="section-sub">Web apps, automations, and games built to solve real problems.</p>
      </div>

      <div class="featured-grid">
        {projects.map((project, index) => (
          <article class={`feature-panel ${index % 2 === 0 ? "feature-panel-orange" : "feature-panel-blue"}`}>
            <h3>{project.name}</h3>
            <p>{project.detail}</p>
            <a class="feature-link" href={project.href}>{project.cta} <span aria-hidden="true">↗</span></a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
